---
pagination:
  data: collections.categoryPages
  size: 1
  alias: category
  addAllPagesToCollections: true
permalink: "{{ category.permalink }}"
layout: "layouts/base.html"
---

{% include "partials/schema/resources-category.json.njk" %}

<div class="layout" data-layout="yogi">

<div>
<h1>{{ category.title }}</h1>
{% set categorySummary = category.category | getResourceCategorySummary %}
{% if categorySummary %}
<p>{{ categorySummary }}</p>
{% endif %}

<hr data-function="spacer">

{% set categoryResources = collections.resources | filterByCategory(category.category) %}
{% set resources = categoryResources %}
{% include "partials/resources-list.html" %}
</div><!-- one -->

<div>
{% include "partials/resources-nav.html" %}
</div><!-- two -->

</div>
